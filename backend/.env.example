# Google Gemini API key (Day 3에서 사용)
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=

# Gemini 모델명 (무료 티어: gemini-2.5-flash 추천)
GEMINI_MODEL=gemini-2.5-flash

# 1차 모델 429(quota) 시 자동 fallback 모델. 무료 티어 한도 더 넉넉.
GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite

# CORS (개발 중에는 * 허용, 배포 시 도메인 지정)
CORS_ALLOW_ORIGINS=*

# Rate limit (시간당 IP당 요청 수) — Day 2에서 사용
RATE_LIMIT_PER_HOUR=20

# 환경 (development | production)
APP_ENV=development

# 기능 B (빠진 관점 분석) — Google Custom Search JSON API
# 무료 100건/일. 두 값 모두 설정해야 활성화됨. 미설정 시 프론트가 카드 자동 숨김.
# 1) https://console.cloud.google.com → Custom Search JSON API 활성화 → API 키 생성
# 2) https://programmablesearchengine.google.com → "전체 웹 검색" 엔진 생성 → 검색 엔진 ID
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
